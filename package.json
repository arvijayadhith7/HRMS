{
  "name": "virtual-nest-hrms",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:backend": "cd backend && node --watch server.js",
    "dev:frontend": "cd frontend-legacy && npm run dev",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "npm run build:frontend && npm run package",
    "build:frontend": "cd frontend-legacy && npm run build",
    "package": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.virtualnest.hrms",
    "productName": "VirtualNest HRMS",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "VirtualNestSetup.exe"
    },
    "files": [
      "electron/**/*",
      "frontend-legacy/dist/**/*",
      "assets/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1"
  }
}
